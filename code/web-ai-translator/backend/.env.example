# ── Paths ──────────────────────────────────────────────────────────────────
# Optional path overrides. Leave unset to use the resolved defaults from
# app/paths.py:
#   - dev (uvicorn from backend/): ./workspace and ./browser_data beside backend/
#   - packaged (PyInstaller):      OS user-data dir (Windows %APPDATA%, macOS
#                                  ~/Library/Application Support, Linux XDG)
# WORKSPACE_DIR=./workspace
# BROWSER_DATA_DIR=./browser_data

HOST=0.0.0.0
PORT=8000

# ── Auth ───────────────────────────────────────────────────────────────────
# Built-in admin account (optional — leave unset to disable).
# When BOTH set, this account can log in without prior registration AND has
# admin privileges (sees every user's jobs, can access legacy workspace/jobs).
# Unset both → no built-in admin; everyone must register through /api/auth/register.
# AUTH_USERNAME=
# AUTH_PASSWORD=

# Session idle timeout in seconds (default 14400 = 4 hours).
# The frontend pauses this timer automatically while a translation job is
# running, so the practical effect is "logout after N hours of true idle".
# SESSION_IDLE_TIMEOUT=14400

# Comma-separated origins allowed to make credentialed CORS requests.
# Wildcard "*" is forbidden alongside credentials. Set this for production:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database (Postgres in prod, SQLite in dev) ─────────────────────────────
# Leave unset to fall back to SQLite under WORKSPACE_DIR/history.db.
# Credentials below match docker-compose.yml (postgres service).
# DATABASE_URL=postgresql+psycopg://wat_user:wat_pass@postgres:5432/wat_db
# ALEMBIC_DATABASE_URL=postgresql+psycopg://wat_user:wat_pass@postgres:5432/wat_db

# ── Celery + Redis ─────────────────────────────────────────────────────────
# Required for the production task queue. If unreachable the dispatcher
# falls back to in-process subprocesses (dev only).
# Each Redis logical DB is dedicated so the broker doesn't trip the cache/pubsub.
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/2
# CACHE_REDIS_URL=redis://redis:6379/3
# PUBSUB_REDIS_URL=redis://redis:6379/4
# CACHE_DEFAULT_TTL=3600

# Dispatch mode: "celery" forces queue mode; "subprocess" forces in-process;
# "auto" (default) tries Celery first and falls back if the broker is silent.
# DISPATCH_MODE=auto

# Celery worker concurrency (Chrome-per-process — keep this at 1).
# CELERY_CONCURRENCY=1

# ── Logging + metrics ──────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json                  # json | console
# Multi-process Prometheus dir (set when running under gunicorn with >1 worker)
# PROMETHEUS_MULTIPROC_DIR=/tmp/prom_multiproc

# ── Rate limits (slowapi) ──────────────────────────────────────────────────
# RATE_LIMIT_TRANSLATE=5/minute
# RATE_LIMIT_UPLOAD=10/minute
# RATE_LIMIT_API=120/minute
# RATE_LIMIT_AUTH=20/minute

# ── Account / proxy pools (multi-tenant Gemini rotation) ───────────────────
# Path to a JSON file with the rotation list. Each entry needs at least
#   { "email": "...", "profile_dir": "/data/browser_data/acct_01" }
# In docker-compose this is mounted at /run/secrets/gemini_accounts.json.
# GEMINI_ACCOUNTS_FILE=/run/secrets/gemini_accounts.json
# ACCOUNT_LEASE_TTL=7200            # how long a worker holds an account (sec)
# ACCOUNT_COOLDOWN=1800             # cooldown after rate-limit hit (sec)

# Path to a newline-separated list of upstream HTTP/SOCKS proxies, e.g.
#   http://user:pass@proxy1:8080
#   socks5://proxy2:1080
# PROXY_LIST_FILE=/run/secrets/proxies.txt
# PROXY_COOLDOWN=900                # cooldown after a proxy failure (sec)

# ── AI backend selection ───────────────────────────────────────────────────
# Which web AI the Playwright translator targets.
# AI_BACKEND=gemini                 # gemini | chatgpt
# TRANSLATOR_MODE=new_browser       # new_browser | cdp
# CDP_URL=http://localhost:9222     # only used when TRANSLATOR_MODE=cdp

# ── VLM fallback (Ollama-based agentic navigation) ─────────────────────────
# VLM_MODEL=llava:7b
# OLLAMA_URL=http://localhost:11434

# ── PDF chunking ───────────────────────────────────────────────────────────
# Target chunk size in characters. Bigger = fewer Gemini round-trips per page
# (faster overall + less context loss) but raises truncation probability.
# Default 3500 ≈ 1 trang A4. Bump to 5000+ if Gemini Pro 2.5 handles it
# cleanly on your docs; drop to 1500 for very dense/technical content.
# PDF_CHUNK_TARGET_SIZE=3500
